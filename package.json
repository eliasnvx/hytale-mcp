{
  "name": "hytale-mcp",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "hytale-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "cache:build": "tsx scripts/build-cache.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "inspect": "npx @modelcontextprotocol/inspector dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lunr": "^2.3.9",
    "mustache": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/lunr": "^2.3.7",
    "@types/mustache": "^4.2.6",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
