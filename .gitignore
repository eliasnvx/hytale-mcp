# Build output
dist/
*.js.map
*.d.ts.map

# Dependencies
node_modules/

# Cache — rebuild with npm run cache:build
# data/ is COMMITTED (pre-built JSON for npm consumers)
# only exclude temporary build artifacts
data/.tmp/
data/.lock

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# IDE
.idea/
*.iml
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~

# Claude Code — personal local overrides (not team rules)
CLAUDE.local.md

# Vitest
coverage/
.vitest-cache/

# TypeScript
*.tsbuildinfo

# Scripts output (temp files from cache builder)
scripts/.tmp/
scripts/output/

# MCP Inspector cache
.mcp-inspector/

# Ignore all markdown files in root except README and rules
/*.md
!/README.md

